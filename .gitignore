.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# LaTeX build intermediates (the final PDF may still be committed)
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc

# Downloaded source data and generated outputs
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
